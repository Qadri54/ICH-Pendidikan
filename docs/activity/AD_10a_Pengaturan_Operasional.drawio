    <mxCell id="e04" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_geo_lat" target="a_simpan_geo" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Simpan geo → System validasi -->
    <mxCell id="e05" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_simpan_geo" target="s_val_geo" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Tidak Valid → error -->
    <mxCell id="e06" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_val_geo" target="s_err_geo" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e06_lbl" value="Tidak Valid" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e06">
      <mxGeometry x="-0.5" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
    </mxCell>

    <!-- Error → loop back ke isi koordinat (via x=415) -->
    <mxCell id="e07" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="s_err_geo" target="a_geo_lat" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="415" y="570"/>
          <mxPoint x="415" y="387"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Valid → simpan geofence -->
    <mxCell id="e08" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_val_geo" target="s_save_geo" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e08_lbl" value="Valid" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e08">
      <mxGeometry x="0.5" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
    </mxCell>

    <!-- Simpan geofence → end -->
    <mxCell id="e08b" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_save_geo" target="a_end" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Pilih → Jam Absensi (via sisi kanan x=390) -->
    <mxCell id="e09" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="a_pilih" target="a_jam" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="390" y="287"/>
          <mxPoint x="390" y="770"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e09_lbl" value="Jam Absensi" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e09">
      <mxGeometry x="-0.3" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
    </mxCell>

    <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_jam" target="a_simpan_jam" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Simpan jam → System simpan -->
    <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_simpan_jam" target="s_save_jam" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- System simpan jam → end -->
    <mxCell id="e11b" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_save_jam" target="a_end" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Pilih → Toggle Pendaftaran (via sisi kiri x=25) -->
    <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="a_pilih" target="a_toggle" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="25" y="287"/>
          <mxPoint x="25" y="967"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e12_lbl" value="Toggle&lt;br&gt;Pendaftaran" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e12">
      <mxGeometry x="-0.3" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
