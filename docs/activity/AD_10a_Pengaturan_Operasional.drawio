    <!-- Title -->
    <mxCell id="title" value="AD_10a — Pengaturan Operasional (Geofence / Jam Absensi / Toggle Pendaftaran)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="20" y="10" width="820" height="40" as="geometry"/>
    </mxCell>

    <!-- Lane 1: Admin -->
    <mxCell id="lane1" value="Admin" style="swimlane;startSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="20" y="60" width="400" height="1090" as="geometry"/>
    </mxCell>

    <!-- Lane 2: System -->
    <mxCell id="lane2" value="System" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="420" y="60" width="400" height="1090" as="geometry"/>
    </mxCell>

    <!-- ===== ADMIN LANE ===== -->

    <mxCell id="a_start" value="" style="ellipse;aspect=fixed;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="220" y="100" width="30" height="30" as="geometry"/>
    </mxCell>

    <!-- y=165 -->
    <mxCell id="a_open" value="Buka Halaman Pengaturan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="140" y="165" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- y=255: 3-way decision -->
    <mxCell id="a_pilih" value="Pilih Pengaturan" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="170" y="255" width="130" height="65" as="geometry"/>
    </mxCell>

    <!-- ── Geofence (branch tengah, langsung ke bawah) ── -->

    <!-- y=360 -->
    <mxCell id="a_geo_lat" value="Isi Koordinat (lat/lng)&lt;br&gt;&amp; Radius Geofence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="140" y="360" width="180" height="55" as="geometry"/>
    </mxCell>

    <!-- y=455: sejajar s_val_geo -->
    <mxCell id="a_simpan_geo" value="Klik Simpan Geofence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="140" y="455" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- ── Jam Absensi (branch kanan, via x=390) ── -->

    <!-- y=745 -->
    <mxCell id="a_jam" value="Isi Jam Absensi&lt;br&gt;(Check-in)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="140" y="745" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- y=835: sejajar s_save_jam -->
    <mxCell id="a_simpan_jam" value="Klik Simpan Jam" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="140" y="835" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- ── Toggle Pendaftaran (branch kiri, via x=25) ── -->

    <!-- y=940: sejajar s_toggle -->
    <mxCell id="a_toggle" value="Klik Toggle&lt;br&gt;Buka / Tutup Pendaftaran" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="140" y="940" width="180" height="55" as="geometry"/>
    </mxCell>

    <mxCell id="a_end" value="" style="ellipse;aspect=fixed;fillColor=#000000;strokeColor=#000000;strokeWidth=4;" vertex="1" parent="1">
      <mxGeometry x="218" y="1038" width="34" height="34" as="geometry"/>
    </mxCell>

    <!-- ===== SYSTEM LANE ===== -->

    <!-- y=450: sejajar a_simpan_geo (rhombus center ≈ a_simpan_geo center) -->
    <mxCell id="s_val_geo" value="Validasi Koordinat?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="570" y="450" width="130" height="65" as="geometry"/>
    </mxCell>

    <!-- y=545: Tidak Valid branch -->
    <mxCell id="s_err_geo" value="Tampil Error Koordinat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="540" y="545" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- y=640: Valid branch -->
    <mxCell id="s_save_geo" value="Simpan AttendanceSetting&lt;br&gt;(geofence)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="540" y="640" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- y=835: sejajar a_simpan_jam -->
    <mxCell id="s_save_jam" value="Simpan AttendanceSetting&lt;br&gt;(jam absensi)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="540" y="835" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- y=940: sejajar a_toggle -->
    <mxCell id="s_toggle" value="Update RegistrationSetting&lt;br&gt;(buka / tutup)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="540" y="940" width="180" height="55" as="geometry"/>
    </mxCell>

    <!-- ===== EDGES ===== -->

    <mxCell id="e01" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_start" target="a_open" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e02" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_open" target="a_pilih" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Pilih → Geofence (keluar bawah, langsung turun) -->
    <mxCell id="e03" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_pilih" target="a_geo_lat" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e03_lbl" value="Geofence" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e03">
