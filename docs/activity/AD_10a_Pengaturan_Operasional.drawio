    <!-- Toggle → System update -->
    <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="a_toggle" target="s_toggle" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- System toggle → end -->
    <mxCell id="e13b" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_toggle" target="a_end" parent="1">
