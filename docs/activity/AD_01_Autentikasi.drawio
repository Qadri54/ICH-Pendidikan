    <!-- ===== SYSTEM LANE ===== -->

    <!-- Validasi Kredensial -->
    <mxCell id="s_validate" value="Validasi Kredensial?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
