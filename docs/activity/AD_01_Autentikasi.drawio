  <diagram name="Page-1">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="AD_01 — Autentikasi (Admin / Guru)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="20" y="10" width="820" height="40" as="geometry"/>
    </mxCell>

    <!-- Lane 1: User -->
    <mxCell id="lane1" value="User" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="20" y="60" width="400" height="720" as="geometry"/>
    </mxCell>

    <!-- Lane 2: System -->
    <mxCell id="lane2" value="System" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="420" y="60" width="400" height="720" as="geometry"/>
    </mxCell>

    <!-- ===== USER LANE ===== -->

    <!-- Start -->
    <mxCell id="u_start" value="" style="ellipse;aspect=fixed;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="205" y="100" width="30" height="30" as="geometry"/>
    </mxCell>

    <!-- Buka Halaman Login -->
    <mxCell id="u_open" value="Buka Halaman Login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="130" y="165" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Isi Email & Password -->
    <mxCell id="u_fill" value="Isi Email &amp; Password" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="130" y="255" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Akses Dashboard -->
    <mxCell id="u_dashboard" value="Akses Dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="130" y="490" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Klik Logout -->
    <mxCell id="u_logout" value="Klik Logout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="130" y="570" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- End -->
    <mxCell id="u_end" value="" style="ellipse;aspect=fixed;fillColor=#000000;strokeColor=#000000;strokeWidth=4;" vertex="1" parent="1">
      <mxGeometry x="203" y="655" width="34" height="34" as="geometry"/>
    </mxCell>

    <!-- ===== SYSTEM LANE ===== -->

    <!-- Validasi Kredensial -->
    <mxCell id="s_validate" value="Validasi Kredensial?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="555" y="255" width="130" height="65" as="geometry"/>
    </mxCell>

    <!-- Tampil Pesan Error -->
    <mxCell id="s_error" value="Tampil Pesan Error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="530" y="350" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Cek Role User -->
    <mxCell id="s_role" value="Cek Role User" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="555" y="415" width="130" height="65" as="geometry"/>
    </mxCell>

    <!-- Redirect Sesuai Role -->
    <mxCell id="s_redirect" value="Redirect Dashboard Sesuai Role" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="530" y="500" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Hapus Sesi -->
    <mxCell id="s_clear" value="Hapus Sesi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="530" y="580" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Redirect ke Login -->
    <mxCell id="s_redir_login" value="Redirect ke Halaman Login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="530" y="655" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- ===== EDGES ===== -->

    <!-- Start → Buka Login -->
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_start" target="u_open" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Buka Login → Isi Form -->
    <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_open" target="u_fill" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Isi Form → Validasi -->
    <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_fill" target="s_validate" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Validasi → Error (Gagal) -->
    <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_validate" target="s_error" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e4_lbl" value="Gagal" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e4">
      <mxGeometry x="-0.5" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
    </mxCell>

    <!-- Error → Isi Form (loop back) -->
    <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="s_error" target="u_fill" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="410" y="375"/>
          <mxPoint x="410" y="280"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Validasi → Cek Role (Berhasil) -->
    <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_validate" target="s_role" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e6_lbl" value="Berhasil" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e6">
      <mxGeometry x="0.5" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
    </mxCell>

    <!-- Cek Role → Redirect -->
    <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_role" target="s_redirect" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Redirect → Dashboard -->
    <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_redirect" target="u_dashboard" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Dashboard → Logout -->
    <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_dashboard" target="u_logout" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Logout → Hapus Sesi -->
    <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_logout" target="s_clear" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Hapus Sesi → Redirect Login -->
    <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_clear" target="s_redir_login" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Redirect Login → End -->
    <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_redir_login" target="u_end" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
