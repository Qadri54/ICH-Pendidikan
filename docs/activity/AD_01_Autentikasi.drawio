    </mxCell>

    <!-- Redirect Sesuai Role -->
    <mxCell id="s_redirect" value="Redirect Dashboard&lt;br&gt;Sesuai Role" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="540" y="570" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Kirim Link Reset -->
    <mxCell id="s_send_link" value="Kirim Link Reset&lt;br&gt;ke Email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="540" y="540" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Update Password -->
    <mxCell id="s_update_pass" value="Update Password" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="540" y="720" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Hapus Sesi -->
    <mxCell id="s_clear" value="Hapus Sesi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="540" y="810" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Redirect ke Login -->
    <mxCell id="s_redir_login" value="Redirect ke Halaman Login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="540" y="890" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- ===== EDGES ===== -->

    <!-- Start → Buka Login -->
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_start" target="u_open" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Buka Login → Isi Form -->
    <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_open" target="u_fill" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Isi Form → Lupa Password? -->
    <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_fill" target="u_forgot_dec" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Lupa Password? → Isi Email Reset (Ya) -->
    <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_forgot_dec" target="u_reset_email" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e4_lbl" value="Ya" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e4">
      <mxGeometry x="-0.5" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
    </mxCell>

    <!-- Lupa Password? → System Validasi (Tidak = Login biasa) -->
    <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_forgot_dec" target="s_validate" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e5_lbl" value="Tidak" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e5">
      <mxGeometry x="-0.3" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
    </mxCell>

    <!-- User Isi Email Reset → System Kirim Link -->
    <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_reset_email" target="s_send_link" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- System Kirim Link → User Buka Link -->
    <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_send_link" target="u_open_link" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- User Buka Link → Isi Password Baru -->
    <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_open_link" target="u_new_pass" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- User Isi Password Baru → System Update Password -->
    <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_new_pass" target="s_update_pass" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- System Validate → Tampil Error (Gagal) -->
    <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_validate" target="s_error" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e10_lbl" value="Gagal" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e10">
      <mxGeometry x="-0.5" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
    </mxCell>

    <!-- System Error → User Isi Form (loop back) -->
    <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="s_error" target="u_fill" parent="1">
