        <Array as="points">
          <mxPoint x="380" y="335"/>
          <mxPoint x="380" y="225"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- System Validate → Cek Role (Berhasil) -->
    <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_validate" target="s_role" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e12_lbl" value="Berhasil" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e12">
      <mxGeometry x="0.5" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
    </mxCell>

    <!-- System Cek Role → Redirect -->
    <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_role" target="s_redirect" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- System Redirect → User Dashboard -->
    <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_redirect" target="u_dashboard" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- User Dashboard → Logout -->
    <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_dashboard" target="u_logout" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- User Logout → System Hapus Sesi -->
    <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="u_logout" target="s_clear" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- System Hapus Sesi → Redirect Login -->
    <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_clear" target="s_redir_login" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- System Redirect Login → End -->
    <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s_redir_login" target="u_end" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

