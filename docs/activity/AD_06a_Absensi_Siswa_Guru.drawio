    </mxCell>

    <mxCell id="e06" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="g_tandai" target="g_submit" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Guru submit → System validasi -->
    <mxCell id="e07" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="g_submit" target="sys_validasi" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Validasi Tidak → error -->
    <mxCell id="e08" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sys_validasi" target="sys_error" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e08_lbl" value="Tidak" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e08">
      <mxGeometry x="-0.5" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
    </mxCell>

    <!-- Error → loop back ke Guru tandai -->
    <mxCell id="e09" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="sys_error" target="g_tandai" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="415" y="725"/>
          <mxPoint x="415" y="535"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Validasi Ya → simpan -->
    <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sys_validasi" target="sys_simpan" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e10_lbl" value="Ya" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;" vertex="1" connectable="0" parent="e10">
      <mxGeometry x="0.5" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
    </mxCell>

    <!-- System simpan → Guru konfirmasi -->
    <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sys_simpan" target="g_konfirmasi" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="g_konfirmasi" target="g_end" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

  </root>
