      <mxGeometry x="420" y="60" width="400" height="930" as="geometry"/>
    </mxCell>

    <!-- ===== GURU LANE ===== -->

    <mxCell id="g_start" value="" style="ellipse;aspect=fixed;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="205" y="100" width="30" height="30" as="geometry"/>
    </mxCell>

    <!-- y=165 -->
    <mxCell id="g_open" value="Buka Halaman Absensi Siswa" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="130" y="165" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- y=255 -->
    <mxCell id="g_pilih_tanggal" value="Pilih Tanggal &amp; Kelas" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="130" y="255" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- y=420: setelah sys_load response -->
    <mxCell id="g_lihat_siswa" value="Lihat Daftar Siswa di Kelas" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="130" y="420" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- y=510 -->
    <mxCell id="g_tandai" value="Tandai Hadir / Tidak Hadir&lt;br&gt;per Siswa" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="130" y="510" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- y=600 -->
    <mxCell id="g_submit" value="Submit Absensi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="130" y="600" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- y=780: sejajar dengan sys_simpan -->
    <mxCell id="g_konfirmasi" value="Lihat Konfirmasi Berhasil" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="130" y="780" width="180" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="g_end" value="" style="ellipse;aspect=fixed;fillColor=#000000;strokeColor=#000000;strokeWidth=4;" vertex="1" parent="1">
      <mxGeometry x="203" y="880" width="34" height="34" as="geometry"/>
    </mxCell>

    <!-- ===== SYSTEM LANE ===== -->

    <!-- y=340: merespons Guru pilih tanggal -->
    <mxCell id="sys_load" value="Tampilkan Siswa Kelas Guru" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="540" y="340" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- y=600: sejajar dengan g_submit -->
    <mxCell id="sys_validasi" value="Validasi Data Absensi?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="570" y="600" width="130" height="65" as="geometry"/>
    </mxCell>

    <!-- y=700: Tidak branch -->
    <mxCell id="sys_error" value="Tampil Pesan Error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="540" y="700" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- y=780: Ya branch, sejajar dengan g_konfirmasi -->
    <mxCell id="sys_simpan" value="Simpan Batch StudentAttendance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="540" y="780" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- ===== EDGES ===== -->

    <mxCell id="e01" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="g_start" target="g_open" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e02" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="g_open" target="g_pilih_tanggal" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Guru pilih tanggal → System load siswa -->
    <mxCell id="e03" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="g_pilih_tanggal" target="sys_load" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- System load → Guru lihat daftar siswa -->
    <mxCell id="e04" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sys_load" target="g_lihat_siswa" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e05" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="g_lihat_siswa" target="g_tandai" parent="1">
